generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  tasks         Task[]

  @@map("users")
}

model Task {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  text       String
  due_date   DateTime?
  created_at DateTime @default(now())

  @@index([userId])
  @@map("tasks")
}
